{
	"schemaVersion": 1,
	"id": "smores",
	"version": "${version}",
	"name": "Smores",
	"description": "Eat the ingredients or make a smore for more health.",
	"authors": [
		"brickersnapper"
	],
	"contact": {
		"homepage": "localhost",
		"sources": "https://github.com/brickersnapper/minecraftsmores"
	},
	"license": "CC0-1.0",
	"icon": "assets/smores/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.brickersnapper.smores.Smores"
		],
		"client": [
			"com.brickersnapper.smores.SmoresClient"
		]
	},
	"mixins": [
		"smores.mixins.json",
		{
			"config": "smores.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.3",
		"minecraft": "~1.21.5",
		"java": ">=21",
		"fabric-api": "*"
	}
}